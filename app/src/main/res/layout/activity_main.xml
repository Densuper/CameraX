<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_backdrop"
    android:clipToPadding="false"
    android:paddingBottom="8dp">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_preview_frame"
        android:clipToOutline="true"
        app:implementationMode="compatible"
        app:layout_constraintBottom_toTopOf="@id/bottomDock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:scaleType="fillCenter" />

    <com.camerax.app.ui.DetectionOverlayView
        android:id="@+id/detectionOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_overlay_subtle_rounded"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/flashButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Flash toggle"
                android:background="@drawable/bg_icon_circle"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_flash_24"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/flashModeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_overlay_panel_rounded"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="OFF"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/topHdrLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:text="HDR"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recordingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_overlay_subtle_rounded"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="REC"
            android:textColor="#FF453A"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="Settings"
            android:background="@drawable/bg_overlay_panel_rounded"
            android:padding="6dp"
            android:src="@drawable/ic_settings_24"
            android:tint="#D3E7FF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/topControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_overlay_panel_rounded"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <com.camerax.app.ui.LightGraphView
            android:id="@+id/lightGraph"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_overlay_inner_rounded" />

        <TextView
            android:id="@+id/lightValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="L: --"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/apertureMinusButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:text="-" />

        <TextView
            android:id="@+id/apertureText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="f/auto"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aperturePlusButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:text="+" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_overlay_subtle_rounded"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="Ready"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/settingsStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_overlay_subtle_rounded"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:text="2K · STAB"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomDock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_overlay_panel_rounded"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:id="@+id/modeToggleContainer"
            android:layout_width="196dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_mode_toggle_track"
            android:padding="4dp">

            <View
                android:id="@+id/modeBubble"
                android:layout_width="94dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_mode_toggle_bubble" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/photoModeButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="PHOTO"
                    android:textColor="#141414"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/videoModeButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="VIDEO"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/zoomControlsRow"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <FrameLayout
                android:id="@+id/galleryThumb"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_overlay_light_rounded"
                android:clipToOutline="true"
                app:layout_constraintBottom_toBottomOf="@id/shutterButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/shutterButton">

                <ImageView
                    android:id="@+id/galleryThumbPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Latest media preview"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/frontCameraButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_overlay_panel_rounded"
                android:contentDescription="Front camera"
                android:padding="8dp"
                android:src="@drawable/ic_selfie_half"
                android:tint="#FFFFFF"
                app:layout_constraintBottom_toBottomOf="@id/shutterButton"
                app:layout_constraintEnd_toStartOf="@id/shutterButton"
                app:layout_constraintTop_toTopOf="@id/shutterButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shutterButton"
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text=""
                app:cornerRadius="39dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.camerax.app.ui.ZoomGridSliderView
                android:id="@+id/zoomGridSlider"
                android:layout_width="46dp"
                android:layout_height="78dp"
                app:layout_constraintBottom_toBottomOf="@id/shutterButton"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@id/shutterButton"
                app:layout_constraintTop_toTopOf="@id/shutterButton" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <View
        android:id="@+id/captureFlashOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0"
        android:background="#FFFFFF"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
